# Copy this file to server/.env
PORT=8787
HOST=127.0.0.1
CLIENT_ORIGIN=http://localhost:5173

# Draft writing provider.
# auto = Gemini if GEMINI_API_KEY exists, otherwise Anthropic if ANTHROPIC_API_KEY exists, otherwise local-template.
# You can also set: gemini, anthropic, local
DRAFT_PROVIDER=auto

# Optional cheap/free draft-writing model.
# Use this for normal email writing and rewrite buttons.
GEMINI_API_KEY=
GEMINI_DRAFT_MODEL=gemini-2.5-flash-lite

# Optional Anthropic key.
# Still required for paid web-search enrichment, because that uses Anthropic's web_search tool.
ANTHROPIC_API_KEY=
ANTHROPIC_DRAFT_MODEL=claude-sonnet-4-20250514
ANTHROPIC_RESEARCH_MODEL=claude-sonnet-4-20250514

# Cost controls
ALLOW_WEB_RESEARCH_DEFAULT=false
MAX_WEB_SEARCH_USES_PER_SCHOOL=2
MAX_CONTACTS_PER_SCHOOL=3
