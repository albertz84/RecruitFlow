# Copy this file to server/.env
PORT=3000
HOST=0.0.0.0
CLIENT_ORIGIN=http://localhost:5173
# Optional comma-separated list for production/previews.
CLIENT_ORIGINS=http://localhost:5173

# Required for real Google login.
# Create an OAuth 2.0 Client ID in Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Required before deploying publicly. Use a long random value.
SESSION_SECRET=change-this-to-a-long-random-string

# Comma-separated Google emails allowed to use protected admin endpoints.
ADMIN_EMAILS=

# Supabase Postgres. Required in production.
# Keep the service-role key on Render only. Do not expose it to Vercel.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Draft writing provider.
# auto = Gemini if GEMINI_API_KEY exists, otherwise Anthropic if ANTHROPIC_API_KEY exists, otherwise local-template.
# You can also set: gemini, anthropic, local
DRAFT_PROVIDER=auto

# Optional cheap/free draft-writing model.
# Use this for normal email writing and rewrite buttons.
GEMINI_API_KEY=
GEMINI_DRAFT_MODEL=gemini-2.5-flash-lite

# Optional Anthropic key.
ANTHROPIC_API_KEY=
ANTHROPIC_DRAFT_MODEL=claude-sonnet-4-20250514
MAX_CONTACTS_PER_SCHOOL=3
